{
  "name": "big-demo-project",
  "version": "1.2.9",
  "description": "Example project with many dependencies and configuration entries",
  "author": "Developer",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "webpack --mode production",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "deploy": "echo Deploying...",
    "backup": "tar -czf backup.tar.gz .",
    "generate": "node scripts/generate.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "axios": "^1.6.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.0",
    "uuid": "^9.0.1",
    "socket.io": "^4.7.0",
    "sharp": "^0.33.0",
    "multer": "^1.4.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "webpack": "^5.0.0",
    "babel": "^7.0.0",
    "typescript": "^5.3.0"
  },
  "config": {
    "server": {
      "port": 8000,
      "host": "localhost",
      "https": false
    },
    "database": {
      "type": "mongodb",
      "host": "127.0.0.1",
      "port": 27017,
      "name": "app_db",
      "replicaSet": null
    },
    "features": {
      "auth": true,
      "payments": false,
      "notifications": true,
      "analytics": true
    }
  },
  "modules": [
    {
      "name": "auth",
      "enabled": true,
      "permissions": ["login", "logout", "register"]
    },
    {
      "name": "payments",
      "enabled": false,
      "providers": ["stripe", "paypal"]
    },
    {
      "name": "analytics",
      "enabled": true,
      "tracking": {
        "pageViews": true,
        "events": true,
        "errors": true
      }
    }
  ],
  "logs": [
    { "level": "info", "message": "Server started", "timestamp": "2024-01-01T10:00:00Z" },
    { "level": "warn", "message": "Memory usage high", "timestamp": "2024-01-01T11:00:00Z" },
    { "level": "error", "message": "Database connection failed", "timestamp": "2024-01-01T12:00:00Z" }
  ]
}